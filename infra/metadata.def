\cs_new_protected:Npn \nwpu@set@chs@major #1
  {
    \cs_gset:Npn \nwpu@chs@major {#1}
    \bool_if:NF \l__nwpu_major_en_explicit_bool
      {
        \prop_get:NnNTF \l__nwpu_major_en_prop {#1} \l_tmpa_tl
          { \cs_gset:Npx \nwpu@eng@major { \l_tmpa_tl } }
          { \cs_gset:Npn \nwpu@eng@major { \chs@space } }
      }
  }
\cs_new_protected:Npn \nwpu@set@eng@major #1
  {
    \bool_set_true:N \l__nwpu_major_en_explicit_bool
    \cs_gset:Npn \nwpu@eng@major {#1}
  }
\cs_new_protected:Npn \nwpu@set@chs@advisor #1
  { \cs_gset:Npn \nwpu@chs@advisor { \blindreview{#1} } }
\cs_new_protected:Npn \nwpu@set@eng@advisor #1
  { \cs_gset:Npn \nwpu@eng@advisor { \blindreview{#1} } }
\bool_new:N \l__nwpu_rank_en_explicit_bool                    % 是否手动指定英文职称
\prop_new:N \l__nwpu_rank_en_prop                             % 职称中英文对照表
\prop_set_from_keyval:Nn \l__nwpu_rank_en_prop
  {
    教授 = Professor,
    副教授 = Associate~Professor,
    研究员 = Researcher,
    讲师 = Lecturer,
  }
\cs_new_protected:Npn \nwpu@set@chs@advisor@rank #1
  {
    \cs_gset:Npn \nwpu@chs@advisorAcademicRank { \nobreakspace\nobreakspace #1 }
    \bool_if:NF \l__nwpu_rank_en_explicit_bool
      {
        \prop_get:NnNTF \l__nwpu_rank_en_prop {#1} \l_tmpa_tl
          { \cs_gset:Npx \nwpu@eng@advisorAcademicRank { \l_tmpa_tl } }
          { \cs_gset:Npn \nwpu@eng@advisorAcademicRank { \chs@space } }
      }
  }
\cs_new_protected:Npn \nwpu@set@eng@advisor@rank #1
  {
    \bool_set_true:N \l__nwpu_rank_en_explicit_bool
    \cs_gset:Npn \nwpu@eng@advisorAcademicRank {#1}
  }
\cs_new_protected:Npn \nwpu@set@chs@funding #1
  { \cs_gset:Npn \nwpu@chs@funding {#1} }
\cs_new_protected:Npn \nwpu@set@eng@funding #1
  { \cs_gset:Npn \nwpu@eng@funding {#1} }
\cs_new_protected:Npn \nwpu@set@chs@schoolname #1
  { \cs_gset:Npn \nwpu@chs@schoolname {#1} }
\cs_new_protected:Npn \nwpu@set@eng@schoolname #1
  { \cs_gset:Npn \nwpu@eng@schoolname {#1} }
\cs_new_protected:Npn \nwpu@set@studentnumber #1
  { \cs_gset:Npn \nwpu@uid { \blindreview{#1} } }
\cs_new_protected:Npn \nwpu@set@schoolcode #1
  { \cs_gset:Npn \nwpu@schoolcode {#1} }
\cs_new_protected:Npn \nwpu@set@classnumber #1
  { \cs_gset:Npn \nwpu@classnumber {#1} }
\cs_new_protected:Npn \nwpu@set@securitylevel #1
  { \cs_gset:Npn \nwpu@securitylevel {#1} }
%%-----------------------------------------------------------------------------%
\DeclareKeys [ nwputhesis ]
  {
    title                 .code:n = \nwpu@set@chs@title {#1},
    title-line-a          .code:n = \nwpu@set@chs@title@lineA {#1},
    title-line-b          .code:n = \nwpu@set@chs@title@lineB {#1},
    title*                .code:n = \nwpu@set@eng@title {#1},
    title-en              .code:n = \nwpu@set@eng@title {#1},
    author                .code:n = \nwpu@set@chs@author {#1},
    author*               .code:n = \nwpu@set@eng@author {#1},
    author-en             .code:n = \nwpu@set@eng@author {#1},
    date                  .code:n = \nwpu@set@chs@date {#1},
    date*                 .code:n = \nwpu@set@eng@date {#1},
    date-en               .code:n = \nwpu@set@eng@date {#1},
    year                  .code:n = \nwpu@set@year {#1},
    month                 .code:n = \nwpu@set@month {#1},
    school                .code:n = \nwpu@set@school {#1},
    major                 .code:n = \nwpu@set@chs@major {#1},
    major*                .code:n = \nwpu@set@eng@major {#1},
    major-en              .code:n = \nwpu@set@eng@major {#1},
    advisor               .code:n = \nwpu@set@chs@advisor {#1},
    advisor*              .code:n = \nwpu@set@eng@advisor {#1},
    advisor-en            .code:n = \nwpu@set@eng@advisor {#1},
    advisor-rank          .code:n = \nwpu@set@chs@advisor@rank {#1},
    advisor-rank*         .code:n = \nwpu@set@eng@advisor@rank {#1},
    advisor-rank-en       .code:n = \nwpu@set@eng@advisor@rank {#1},
    advisor-title         .code:n = \nwpu@set@chs@advisor@rank {#1},
    advisor-title*        .code:n = \nwpu@set@eng@advisor@rank {#1},
    advisor-title-en      .code:n = \nwpu@set@eng@advisor@rank {#1},
    funding               .code:n = \nwpu@set@chs@funding {#1},
    funding*              .code:n = \nwpu@set@eng@funding {#1},
    funding-en            .code:n = \nwpu@set@eng@funding {#1},
    school-name           .code:n = \nwpu@set@chs@schoolname {#1},
    school-name*          .code:n = \nwpu@set@eng@schoolname {#1},
    school-name-en        .code:n = \nwpu@set@eng@schoolname {#1},
    student-number        .code:n = \nwpu@set@studentnumber {#1},
    studentnumber         .code:n = \nwpu@set@studentnumber {#1},
    school-code           .code:n = \nwpu@set@schoolcode {#1},
    schoolcode            .code:n = \nwpu@set@schoolcode {#1},
    class-number          .code:n = \nwpu@set@classnumber {#1},
    classnumber           .code:n = \nwpu@set@classnumber {#1},
    security-level        .code:n = \nwpu@set@securitylevel {#1},
    securitylevel         .code:n = \nwpu@set@securitylevel {#1},
  }
\NewDocumentCommand \nwputhesissetup { m }
  {
    \bool_set_true:N \l__nwpu_in_setup_bool
    \SetKeys [ nwputhesis ] {#1}
    \bool_set_false:N \l__nwpu_in_setup_bool
  }
\ExplSyntaxOff
