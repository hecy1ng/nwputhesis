%% This file is part of nwputhesis.
%% It is loaded internally by nwputhesis.cls.

%%=============================================================================%
%% 论文元数据填写
%%-----------------------------------------------------------------------------%
\ExplSyntaxOn
\cs_new:Npn \chs@space { \char"3000 }                         % 全角空格
%%-----------------------------------------------------------------------------%
\cs_new:Npn \nwpu@chs@title { \chs@space }                    % 标题（中文）
\cs_new:Npn \nwpu@chs@title@lineA {}                         % 本科题目第一行（手动）
\cs_new:Npn \nwpu@chs@title@lineB {}                         % 本科题目第二行（手动）
\cs_new:Npn \nwpu@chs@author { \chs@space }                   % 作者（中文）
\cs_new:Npn \nwpu@chs@school { \chs@space }                   % 学院（中文）
\cs_new:Npn \nwpu@chs@major { \chs@space }                    % 专业（中文）
\cs_new:Npn \nwpu@chs@advisor { \chs@space }                  % 导师（中文）
\cs_new:Npn \nwpu@chs@advisorAcademicRank { \chs@space }      % 导师职称（中文）
\cs_new:Npn \nwpu@chs@funding { \chs@space }                  % 基金赞助（中文）
%%-----------------------------------------------------------------------------%
\cs_new:Npn \nwpu@eng@title { \chs@space }                    % 标题（英文）
\cs_new:Npn \nwpu@eng@author { \chs@space }                   % 作者（英文）
\cs_new:Npn \nwpu@eng@major { \chs@space }                    % 专业（英文）
\cs_new:Npn \nwpu@eng@advisor { \chs@space }                  % 导师（英文）
\cs_new:Npn \nwpu@eng@advisorAcademicRank { \chs@space }      % 导师职称（英文）
\cs_new:Npn \nwpu@eng@funding { \chs@space }                  % 基金赞助（英文）
%%-----------------------------------------------------------------------------%
\int_new:N \l__nwpu_month_int                                  % 月份计数器
\int_set:Nn \l__nwpu_month_int { 1 }                           % 默认1月
\cs_new:Npn \nwpu@year { 2026 }                               % 默认年份
\cs_new:Npn \nwpu@eng@monthname                               % 英文月份名称
  {
    \int_case:nn { \l__nwpu_month_int }
      {
        {  1 } { January }
        {  2 } { February }
        {  3 } { March }
        {  4 } { April }
        {  5 } { May }
        {  6 } { June }
        {  7 } { July }
        {  8 } { August }
        {  9 } { September }
        { 10 } { October }
        { 11 } { November }
        { 12 } { December }
      }
  }
\cs_new:Npn \nwpu@chs@date { \nwpu@year{} 年 \int_use:N \l__nwpu_month_int{} 月 } % 日期（中文）
\cs_new:Npn \nwpu@eng@date { \nwpu@eng@monthname/\nwpu@year } % 日期（英文）
%%-----------------------------------------------------------------------------%
\cs_new:Npn \nwpu@uid { 2000123456 }                          % default 学号
\cs_new:Npn \nwpu@schoolcode { 10699 }                        % default 学校代码
\cs_new:Npn \nwpu@classnumber { O242 }                        % default 分类号
\cs_new:Npn \nwpu@securitylevel { 公开 }                      % default 密级
%%-----------------------------------------------------------------------------%
\cs_new_protected:Npn \nwpu@set@chs@title #1
  { \cs_gset:Npn \nwpu@chs@title {#1} }
\cs_new_protected:Npn \nwpu@set@chs@title@lineA #1
  { \cs_gset:Npn \nwpu@chs@title@lineA {#1} }
\cs_new_protected:Npn \nwpu@set@chs@title@lineB #1
  { \cs_gset:Npn \nwpu@chs@title@lineB {#1} }
\cs_new_protected:Npn \nwpu@set@eng@title #1
  { \cs_gset:Npn \nwpu@eng@title {#1} }
\cs_new_protected:Npn \nwpu@set@chs@author #1
  { \cs_gset:Npn \nwpu@chs@author { \blindreview{#1} } }
\cs_new_protected:Npn \nwpu@set@eng@author #1
  { \cs_gset:Npn \nwpu@eng@author { \blindreview{#1} } }
\cs_new_protected:Npn \nwpu@set@chs@date #1
  { \cs_gset:Npn \nwpu@chs@date {#1} }
\cs_new_protected:Npn \nwpu@set@eng@date #1
  { \cs_gset:Npn \nwpu@eng@date {#1} }
\cs_new_protected:Npn \nwpu@set@year #1
  { \cs_gset:Npn \nwpu@year {#1} }
\cs_new_protected:Npn \nwpu_set_month:n #1
  {
    \regex_match:nnTF { \A \s* \d+ \s* \Z } {#1}
      {
        \int_compare:nNnTF {#1} < { 1 }
          { \nwpu_month_error:n {#1} }
          {
            \int_compare:nNnTF {#1} > { 12 }
              { \nwpu_month_error:n {#1} }
              { \int_set:Nn \l__nwpu_month_int {#1} }
          }
      }
      { \nwpu_month_error:n {#1} }
  }
\cs_new_protected:Npn \nwpu_month_error:n #1
  {
    \ClassError { nwputhesis } { Invalid~month~`#1' }
      { Set~month~to~an~integer~from~1~to~12. }
  }
\cs_new_protected:Npn \nwpu@set@month #1
  { \nwpu_set_month:n {#1} }
\cs_new_protected:Npn \nwpu@set@school #1
  { \cs_gset:Npn \nwpu@chs@school {#1} }
\bool_new:N \l__nwpu_major_en_explicit_bool                    % 是否手动指定英文专业
