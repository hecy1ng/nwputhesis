%% This file is part of nwputhesis.
%% It is loaded internally by nwputhesis.cls.

%%-----------------------------------------------------------------------------%
\ExplSyntaxOn
\RequirePackage{indentfirst}                                % 段首空格设置
\dim_set:Nn \parindent { \nwpuParIndent }
\skip_set:Nn \parskip { \nwpuParSkip }
\linespread{1.0}                                            % 行距
%%-----------------------------------------------------------------------------%
\RequirePackage{ulem}                                       % 下划线
\NewDocumentCommand \dlmu@underline { O{5cm} m }
    { \hspace{1pt}\underline{ \hb@xt@ #1 { \hss #2 \hss } } \hspace{3pt} }
\cs_set_eq:NN \coverunderline \dlmu@underline
%%-----------------------------------------------------------------------------%
\RequirePackage[sf]{titlesec}                               % 章节标题格式
\RequirePackage{titletoc}                                   % 目录格式
\setcounter{secnumdepth}{3}                                 % 标题计数器深度
\setcounter{tocdepth}{2}                                    % 目录中标题深度
\nwpu_if_bachelor:TF                                        % 本科论文章节格式
{
    \renewcommand{\thechapter}{\arabic{chapter}}            % 章节编号保持数字
    \renewcommand{\chaptername}{第\CJKnumber{\thechapter}章}% 章节名称（中文数字）
    \titleformat{\chapter}[hang]{\normalfont\nwpuChapterSize\filcenter\fHei}%
      {第\CJKnumber{\thechapter}章}{1em}{\nwpuChapterSize}
    \titleformat{\section}[hang]{\nwpuSectionSize\fHei}%
      {\nwpuSectionSize\thesection}{0.5em}{}{}
    \titleformat{\subsection}[hang]{\nwpuSubsectionSize\fHei}%
      {\nwpuSubsectionSize\thesubsection}{0.5em}{}{}
    \titleformat{\subsubsection}[hang]{\fHei}%
      {(\arabic{subsubsection})}{0.5em}{}{}
    \titlespacing{\chapter}{0pt}{\nwpuChapterBeforeSkip}{\nwpuChapterAfterSkip}
    \titlespacing{\section}{0pt}{\nwpuSectionBeforeSkip}{\nwpuSectionAfterSkip}
    \titlespacing{\subsection}{0pt}{\nwpuSubsecBeforeSkip}{\nwpuSubsecAfterSkip}
    \titlespacing{\subsubsection}{0pt}{0.25em}{0em}
}
{                                                           % 硕博论文章节格式
    \titleformat{\chapter}[hang]{\normalfont\nwpuChapterSize\filcenter  %
        \sffamily\fHei}{\sffamily\fHei\nwpuChapterSize{\chaptertitlename}}{20pt}{\nwpuChapterSize}%
    \titleformat{\section}[hang]{\sffamily\fHei\nwpuSectionSize}{%       %
        \sffamily\fHei\nwpuSectionSize\thesection}{0.5em}{}{}            %
    \titleformat{\subsection}[hang]{\sffamily\fHei\nwpuSubsectionSize}{% %
        \sffamily\fHei\nwpuSubsectionSize\thesubsection}{0.5em}{}{}      %
    \titleformat{\subsubsection}[hang]{\sffamily\fHei}{%        % 小标题: (4) 标题
        (\arabic{subsubsection})}{0.5em}{}{}                    %
    \titlespacing{\chapter}{0pt}{\nwpuChapterBeforeSkip}{\nwpuChapterAfterSkip}
    \titlespacing{\section}{0pt}{\nwpuSectionBeforeSkip}{\nwpuSectionAfterSkip}
    \titlespacing{\subsection}{0pt}{\nwpuSubsecBeforeSkip}{\nwpuSubsecAfterSkip}
    \titlespacing{\subsubsection}{0pt}{0.25em}{0pt}             %
    \titlespacing{\paragraph}{0pt}{0.25em}{0pt}                 %
}
\dottedcontents{section}[1.16cm]{}{1.8em}{5pt}              % 定义目录中各级标题
\dottedcontents{subsection}[2.00cm]{}{2.7em}{5pt}           % 之间的格式以及缩进
\dottedcontents{subsubsection}[2.86cm]{}{3.4em}{5pt}        %
\cs_new:Npn \nwpu@chs@chaptercname #1 { 第 ~ #1 ~ 章 }     % 目录章节中文标题（硕博）
\cs_new:Npn \nwpu@eng@chaptercname #1 { Chapter ~ #1 }     % 目录章节英文标题
\nwpu_if_bachelor:TF                                        % 本科论文目录章节格式
{
    \cs_new:Npn \nwpu@bcl@chaptercname #1 { 第 \CJKnumber{#1} 章 }% 本科目录章节中文标题
    \titlecontents{section}[1.16cm]{\fSong\graduatecontentsfont}%
    {\contentslabel{1.8em}}{}%
    {\titlerule*[3pt]{\raisebox{0.35ex}{.}}\thecontentspage}[\vspace{0em}]%
    \titlecontents{subsection}[2.00cm]{\fSong\graduatecontentsfont}%
    {\contentslabel{2.7em}}{}%
    {\titlerule*[3pt]{\raisebox{0.35ex}{.}}\thecontentspage}[\vspace{0em}]%
    \titlecontents{subsubsection}[2.86cm]{\fSong\graduatecontentsfont}%
    {\contentslabel{3.4em}}{}%
    {\titlerule*[3pt]{\raisebox{0.35ex}{.}}\thecontentspage}[\vspace{0em}]%
    \titlecontents{chapter}[0pt]{\graduatecontentsfont\fSong\vspace{0.2\baselineskip}}%
    {\contentsmargin{1em}\graduatecontentsfont\fSong\bfseries\makebox[0pt][l]{\nwpu@bcl@chaptercname{\thecontentslabel}}\hspace{3.8em}}%
    {\contentsmargin{1em}\graduatecontentsfont\fSong\bfseries}%
    {\graduatecontentsfont\normalfont\titlerule*[.3pc]{\raisebox{0.35ex}{.}}\thecontentspage}[\vspace{0em}]
}
{
    \dottedcontents{section}[1.16cm]{\fSong\graduatecontentsfont}{1.8em}{3pt}   %
    \dottedcontents{subsection}[2.00cm]{\fSong\graduatecontentsfont}{2.7em}{3pt}%
    \dottedcontents{subsubsection}[2.86cm]{\fSong\graduatecontentsfont}{3.4em}{3pt}
    \nwpu_if_chinese:TF                                      % 硕博中文本地化显示
    {
        \titlecontents{chapter}[0pt]{\fSong\graduatecontentsfont}{\contentsmargin{1em}\fSong\graduatecontentsfont\makebox[0pt  %
            ][l]{\nwpu@chs@chaptercname{\thecontentslabel}}\hspace{%
                3.5em}}{\contentsmargin{1em}\fSong\graduatecontentsfont}{\titlerule*[%
                .3pc]{.}\contentspage}[\vspace{0em}]            %
    }
    {                                                           % 硕博英文
        \dim_new:N \l__nwpu_contents_title_dim
        \dim_new:N \l__nwpu_contents_appendix_dim
        \settowidth{\l__nwpu_contents_title_dim}{\graduatecontentsfont Chapter~000} %
        \settowidth{\l__nwpu_contents_appendix_dim}{\graduatecontentsfont Appendix~M00}
        \titlecontents{chapter}[0pt]{\fSong\graduatecontentsfont}{\contentsmargin{1em}\fSong\graduatecontentsfont\makebox[0pt  %
            ][l]{\nwpu@eng@chaptercname{\thecontentslabel}}\hspace{%
                \l__nwpu_contents_title_dim}}{\contentsmargin{1em}\fSong\graduatecontentsfont}{
            \titlerule*[.3pc]{.}\contentspage}[\vspace{0em}]    %
    }
}
%%-----------------------------------------------------------------------------%
\RequirePackage{fancyhdr}                                   % 页眉设置
\cs_new_protected:Npn \npu@headrule
{
    \rlap{\rule[.7\baselineskip]{\headwidth}{3.4pt}}        %
    \vspace{-1.07\baselineskip}                             %
    \rule[.5\baselineskip]{\headwidth}{0.6pt}               %
    \vspace{-.8\baselineskip}                               %
}
\cs_new_protected:Npn \npu@bcl@headrule                     % 本科页眉线
{
    \makebox[0pt][l]{\rule[.7\baselineskip]{\headwidth}{0.8pt}}%
    \vskip-.8\baselineskip                                  %
}
\renewcommand{\headrule}{                                   %
    \if@fancyplain\let\headrulewidth\plainheadrulewidth\fi  %
    \nwpu_if_bachelor:TF                                    % 本科页眉线
        { \npu@bcl@headrule }                               %
        { \npu@headrule }                                   %
}
\graphicspath{{content/figures/}{figures/}}                % 定义图片文件搜索目录
\nwpu_if_bachelor:TF                                        % 本科论文页眉设置
{
    \pagestyle{fancyplain}                                  % 新增版式 fancyplain
    \fancyhf{}                                              % 清空原有页眉页脚
    \fancyfoot[C,C]{\nwpuHeaderFooterSize~\thepage~}           % 页脚中央显示页码
    \chead{\includegraphics[scale=0.15]{nwpuheader.png}}% 页眉居中（图片）
}
{                                                           % 硕博论文页眉设置
    \nwpu_if_chinese:TF                                     % 中英文章节页眉设置
    {
        \renewcommand{\chaptermark}[1]{                     %
            \markboth{\nwpu@chs@chaptercname\thechapter~~ #1}{}}
    }
    {                                                       %
        \renewcommand{\chaptermark}[1]{                     %
            \markboth{\nwpu@eng@chaptercname\thechapter~~ #1}{}}
    }
    \pagestyle{fancyplain}                                  % 新增版式 fancyplain
    \fancyhf{}                                              % 清空原有页眉页脚
    \fancyfoot[C, C]{\nwpuHeaderFooterSize{\thepage}}          % 页脚中央显示页码
    \fancyhead{}                                            % 页眉清除原有设置
    \fancyhead[COH]{\raisebox{0.5pt}{\nwpuHeaderFooterSize{\leftmark}}}  %
    \nwpu_if_chinese:TF                                     % 中文论文环境
        { \fancyhead[CEH]{\raisebox{0.5pt}{\nwpuHeaderFooterSize{\nwpu@chs@header}}} }
        { \fancyhead[CEH]{\raisebox{0.5pt}{\nwpuHeaderFooterSize{\nwpu@eng@header}}} }
}
%%-----------------------------------------------------------------------------%
\RequirePackage[
    backend=biber,
    style=\l__nwpu_bibstyle_tl,
    gbpunctin = false,
    sorting=none
]{biblatex}                                                 % 参考文献
\nwpu_if_graduate:TF{%
    \DefineBibliographyStrings{english}{in={}}%
    \DefineBibliographyStrings{english}{incn={}}%
}{}
%%-----------------------------------------------------------------------------%
\RequirePackage{enumitem}                                   % 列表格式控制
\setlist{nosep}                                             % 消除间距
%%-----------------------------------------------------------------------------%
\RequirePackage{graphicx}                                   % 插图功能
\RequirePackage[final]{pdfpages}                            % 插入其他 pdf 文件
\RequirePackage{xcolor}                                     % 颜色库
\RequirePackage[labelsep=quad]{caption}                     % 浮动体标题控制
\RequirePackage{subcaption}                                 % 子图
\RequirePackage{wrapfig}                                    % 文字环绕
\RequirePackage{multirow, makecell}                         % 合并单元格
\RequirePackage{longtable}                                  % 长表格（跨页表格）
\RequirePackage{booktabs}                                   % 三线表
\RequirePackage{tabularx}                                   % 定宽表格
\DeclareCaptionFont{cWuhao}{\nwpuCaptionSize}                % 图表标题为五号
\DeclareCaptionFont{cGradFigureCaption}{%
    \fontsize{10.5pt}{9.5pt}\selectfont}                   % 研究生图题：五号，收紧行距
\DeclareCaptionFont{cBclTableCaption}{%
    \fontsize{10.5pt}{14pt}\selectfont\bfseries}           % 本科表题：五号黑体，增大标题行距
\DeclareCaptionFont{cBclFigureCaption}{%
    \fontsize{10.5pt}{11.5pt}\selectfont\fSong}            % 本科图题：五号宋体，行距进一步收紧
\nwpu_if_bachelor:TF
{
    \setlength{\textfloatsep}{\nwpuTextFloatSep}              %
    \setlength{\floatsep}{\nwpuFloatSep}                      %
    \setlength{\intextsep}{\nwpuInTextSep}                    %
    \captionsetup[table]{%
        labelfont=cBclTableCaption,
        textfont=cBclTableCaption,
        aboveskip=12pt,
        belowskip=2pt}
    \captionsetup[figure]{%
        labelfont=cBclFigureCaption,
        textfont=cBclFigureCaption,
        aboveskip=12pt,
        belowskip=2pt}
    \captionsetup[subfigure]{labelformat=simple, aboveskip=10pt, belowskip=-5pt}
}
{
    \setlength{\textfloatsep}{\nwpuTextFloatSep}              %
    \setlength{\floatsep}{\nwpuFloatSep}                      %
    \setlength{\intextsep}{\nwpuInTextSep}                    %
    \captionsetup[table]{labelfont=cWuhao, textfont=cWuhao, aboveskip=10pt, belowskip=0pt}
    \captionsetup[figure]{labelfont=cGradFigureCaption, textfont=cGradFigureCaption, aboveskip=10pt, belowskip=0pt}
    \captionsetup[subfigure]{%
        labelformat=simple,
        labelfont=cWuhao,
        textfont=cWuhao,
        aboveskip=10pt,
        belowskip=0pt}
}
\captionsetup[subtable]{labelformat=simple, aboveskip=10pt, belowskip=-5pt}
\AddToHook{env/tabular/begin}{\nwpuCaptionSize}               % 表格内容为五号
\AddToHook{env/tabularx/begin}{\nwpuCaptionSize}              %
\newcolumntype{C}{>{\centering\arraybackslash}X}            % 等宽居中
\newcolumntype{L}{>{\raggedright\arraybackslash}X}          % 等宽左对齐
\newcolumntype{R}{>{\raggedleft\arraybackslash}X}           % 等宽右对齐
\newcolumntype{Q}[1]{>{\raggedleft\let\newline\\%           % 指定宽度右对齐
        \arraybackslash\hspace{0pt}}p{#1}}                  %
\newcolumntype{O}[1]{>{\centering\let\newline\\%            % 指定宽度居中
        \arraybackslash\hspace{0pt}}p{#1}}                  %
\newcolumntype{P}[1]{>{\raggedright\let\newline\\%          % 指定宽度左对齐
        \arraybackslash\hspace{0pt}}p{#1}}                  %
\renewcommand{\arraystretch}{1.4}                           % 表格行高为 1.4 倍
\dim_set:Nn \heavyrulewidth { \nwpuHeavyRuleWidth }          % 表格上下线宽
\dim_set:Nn \lightrulewidth { \nwpuLightRuleWidth }          % 表格中线宽
%%-----------------------------------------------------------------------------%
\RequirePackage[amsmath,thmmarks]{ntheorem}                 % 定理环境格式
\theorembodyfont{\normalfont\itshape}                       % 主体文字格式
\theoremseparator{\quad}                                    % 标题与主体间隔
\dim_set:Nn \topsep { 0pt }                                  % 设置定理环境间距
\theorempreskip{0pt}                                        % 节前空白大小
\theorempostskip{0pt}                                       % 节后空白大小
\cs_set_protected:Npn \thm@space@setup {                       %
    \thm@preskip=0pt                                        %
    \thm@postskip=0pt}                                      %
\AtBeginDocument{                                           %
    \setlength{\abovedisplayskip}{0pt}                      %
    \setlength{\belowdisplayskip}{0pt}                      %
    \setlength{\abovedisplayshortskip}{0pt}                 %
    \setlength{\belowdisplayshortskip}{0pt}                 %
}                                                           %
{\theoremsymbol{\ensuremath{\square}}                       % 证明环境 囗
    \nwpu_if_chinese:TF
        { \newtheorem*{proof}{证明} }
        { \newtheorem*{proof}{Proof} }
}
\cs_new_protected:Npn \qedinEquation { {\rlap{$\qquad\square$}} }% 公式中添加证毕符号
\nwpu_if_chinese:TF                                         % 定制中文定理环境
{
    \newtheorem{theorem}{定理}[chapter]                     %
    \newtheorem{axiom}[theorem]{公理}                       %
    \newtheorem{corollary}[theorem]{推论}                   %
    \newtheorem{lemma}[theorem]{引理}                       %
    \newtheorem{definition}[theorem]{定义}                  %
    \newtheorem{example}[theorem]{例}                       %
    \newtheorem{proposition}[theorem]{命题}                 %
}
{                                                           % 定制英文定理环境
    \newtheorem{theorem}{Theorem}[chapter]                  %
    \newtheorem{axiom}[theorem]{Axiom}                      %
    \newtheorem{corollary}[theorem]{Corollary}              %
    \newtheorem{lemma}[theorem]{Lemma}                      %
    \newtheorem{definition}[theorem]{Definition}            %
    \newtheorem{example}[theorem]{Example}                  %
    \newtheorem{proposition}[theorem]{Proposition}          %
}
%%-----------------------------------------------------------------------------%
\RequirePackage{listings}                                   % 添加插入代码控制
\lstset{                                                    % 代码样式
    basicstyle=\color[HTML]{000000}\small\ttfamily,         % 等宽字体 10pt 字号
    numbers=left,                                           % 左侧加入行号
    numberstyle=\tiny,                                      % 行号 6pt 字号
    numbersep=5pt,                                          % 行号与代码间隔
    tabsize=4,                                              % 制表符大小
    extendedchars=true,                                     % 拓展字符集显示汉字
    breaklines=true,                                        % 允许自动换行
    keywordstyle=\color[HTML]{0000FF}\bfseries,             % 关键字样式
    numberstyle=\color[HTML]{ff8000},                       % 数字样式
    commentstyle=\color[HTML]{008000}\bfseries,             % 注释样式
    stringstyle=\color[HTML]{A31515}\ttfamily,              % 字符串样式
    showspaces=false,                                       % 不显示空格字符
    showtabs=false,                                         % 不显示制表符
    frame=shadowbox,                                        % 添加阴影边框
    framexrightmargin=5pt,                                  % 边框右边缩进
    framexbottommargin=4pt,                                 % 边框底端缩进
    rulesepcolor=\color[HTML]{C0C0C0},                      % 边框颜色
    showstringspaces=false,                                 % 显示字符串内空格
    escapeinside=`',                                        % 逃逸字符以显示公式
}                                                           %
\lstloadlanguages{C++, Java, Python, Matlab, R, Mathematica}% 默认加载常用语言
%%-----------------------------------------------------------------------------%
\RequirePackage{algorithm}                                  % 算法流程
\RequirePackage{algpseudocode}                              % 伪代码
%%-----------------------------------------------------------------------------%
\RequirePackage{appendix}                                   % 添加附录功能
%%-----------------------------------------------------------------------------%
\RequirePackage{nomencl}                                    % 添加符号表功能
\RequirePackage{multicol}                                   % 页面具体尺寸信息
\makenomenclature                                           % 单栏符号表
\tl_new:N \l__nwpu_nom_sec_tl
\cs_if_exist:NTF \chapter
  { \tl_set:Nn \l__nwpu_nom_sec_tl { chapter } }
  { \tl_set:Nn \l__nwpu_nom_sec_tl { section } }
\cs_set:Npn \thenomenclature {%
    \use:c { \l__nwpu_nom_sec_tl } * { \nomname }
    \if@intoc\addcontentsline{toc}{\l__nwpu_nom_sec_tl}{\nomname}\fi
    \nompreamble
    \list{}{\labelsep=15pt\labelwidth\nom@tempdim\leftmargin\labelwidth\advance
        \leftmargin\labelsep\itemsep\nomitemsep\let\makelabel\nomlabel}%
}
\cs_set:Npn \endthenomenclature {\endlist
    \nompostamble}
\ExplSyntaxOff
%%=============================================================================%
