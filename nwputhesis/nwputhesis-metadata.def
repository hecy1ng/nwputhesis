%% This file is part of nwputhesis.
%% It is loaded internally by nwputhesis.cls.

%%=============================================================================%
%% 论文元数据填写
%%-----------------------------------------------------------------------------%
\ExplSyntaxOn
\cs_new:Npn \chs@colon { \char"FF1A }                         % 中文冒号
\cs_new:Npn \chs@space { \char"3000 }                         % 全角空格
\cs_new:Npn \chs@period { \char"3002 }                        % 中文句号
\cs_new:Npn \chs@question { \char"FF1F }                      % 中文问号
\cs_new:Npn \chs@exclamation { \char"FF01 }                   % 中文感叹号
\cs_new:Npn \chs@comma { \char"FF0C }                         % 中文逗号
\cs_new:Npn \chs@semicolon { \char"FF1B }                     % 中文分号
\cs_new:Npn \chs@leftparenthesis { \char"FF08 }               % 左括号
\cs_new:Npn \chs@rightparenthesis { \char"FF09 }              % 右括号
%%-----------------------------------------------------------------------------%
\cs_new:Npn \nwpu@chs@title { \chs@space }                    % 标题（中文）
\cs_new:Npn \nwpu@chs@coverTitleLineA { \nwpu@chs@title }     % 封皮标题第一行（中文）
\cs_new:Npn \nwpu@chs@coverTitleLineB { \chs@space }          % 封皮标题第二行（中文）
\cs_new:Npn \nwpu@chs@author { \chs@space }                   % 作者（中文）
\cs_new:Npn \nwpu@chs@school { \chs@space }                   % 学院（中文）
\cs_new:Npn \nwpu@chs@major { \chs@space }                    % 专业（中文）
\cs_new:Npn \nwpu@chs@advisor { \chs@space }                  % 导师（中文）
\cs_new:Npn \nwpu@chs@advisorAcademicRank { \chs@space }      % 导师职称（中文）
\cs_new:Npn \nwpu@chs@funding { \chs@space }                  % 基金赞助（中文）
%%-----------------------------------------------------------------------------%
\cs_new:Npn \nwpu@eng@title { \chs@space }                    % 标题（英文）
\cs_new:Npn \nwpu@eng@author { \chs@space }                   % 作者（英文）
\cs_new:Npn \nwpu@eng@major { \chs@space }                    % 专业（英文）
\cs_new:Npn \nwpu@eng@advisor { \chs@space }                  % 导师（英文）
\cs_new:Npn \nwpu@eng@advisorAcademicRank { \chs@space }      % 导师职称（英文）
\cs_new:Npn \nwpu@eng@funding { \chs@space }                  % 基金赞助（英文）
%%-----------------------------------------------------------------------------%
\int_new:N \l__nwpu_month_int                                  % 月份计数器
\int_set:Nn \l__nwpu_month_int { 1 }                           % 默认1月
\cs_new:Npn \nwpu@year { 2026 }                               % 默认年份
\cs_new:Npn \nwpu@eng@monthname                               % 英文月份名称
  {
    \int_case:nn { \l__nwpu_month_int }
      {
        {  1 } { January }
        {  2 } { February }
        {  3 } { March }
        {  4 } { April }
        {  5 } { May }
        {  6 } { June }
        {  7 } { July }
        {  8 } { August }
        {  9 } { September }
        { 10 } { October }
        { 11 } { November }
        { 12 } { December }
      }
  }
\cs_new:Npn \nwpu@chs@date { \nwpu@year{} 年 \int_use:N \l__nwpu_month_int{} 月 } % 日期（中文）
\cs_new:Npn \nwpu@eng@date { \nwpu@eng@monthname/\nwpu@year } % 日期（英文）
%%-----------------------------------------------------------------------------%
\cs_new:Npn \nwpu@uid { 2000123456 }                          % default 学号
\cs_new:Npn \nwpu@schoolcode { 10699 }                        % default 学校代码
\cs_new:Npn \nwpu@classnumber { O242 }                        % default 分类号
\cs_new:Npn \nwpu@securitylevel { 公开 }                      % default 密级
\cs_new:Npn \nwpu@funding { \chs@space }                      % 基金资助
%%-----------------------------------------------------------------------------%
\cs_new_protected:Npn \nwpu@set@chs@title #1
  { \cs_gset:Npn \nwpu@chs@title {#1} }
\cs_new_protected:Npn \nwpu@set@chs@cover@title@line@a #1
  { \cs_gset:Npn \nwpu@chs@coverTitleLineA {#1} }
\cs_new_protected:Npn \nwpu@set@chs@cover@title@line@b #1
  { \cs_gset:Npn \nwpu@chs@coverTitleLineB {#1} }
\cs_new_protected:Npn \nwpu@set@eng@title #1
  { \cs_gset:Npn \nwpu@eng@title {#1} }
\cs_new_protected:Npn \nwpu@set@chs@author #1
  { \cs_gset:Npn \nwpu@chs@author { \blindreview{#1} } }
\cs_new_protected:Npn \nwpu@set@eng@author #1
  { \cs_gset:Npn \nwpu@eng@author { \blindreview{#1} } }
\cs_new_protected:Npn \nwpu@set@chs@date #1
  { \cs_gset:Npn \nwpu@chs@date {#1} }
\cs_new_protected:Npn \nwpu@set@eng@date #1
  { \cs_gset:Npn \nwpu@eng@date {#1} }
\cs_new_protected:Npn \nwpu@set@year #1
  { \cs_gset:Npn \nwpu@year {#1} }
\cs_new_protected:Npn \nwpu_set_month:n #1
  {
    \regex_match:nnTF { \A \s* \d+ \s* \Z } {#1}
      {
        \int_compare:nNnTF {#1} < { 1 }
          { \nwpu_month_error:n {#1} }
          {
            \int_compare:nNnTF {#1} > { 12 }
              { \nwpu_month_error:n {#1} }
              { \int_set:Nn \l__nwpu_month_int {#1} }
          }
      }
      { \nwpu_month_error:n {#1} }
  }
\cs_new_protected:Npn \nwpu_month_error:n #1
  {
    \ClassError { nwputhesis } { Invalid~month~`#1' }
      { Set~month~to~an~integer~from~1~to~12. }
  }
\cs_new_protected:Npn \nwpu@set@month #1
  { \nwpu_set_month:n {#1} }
\cs_new_protected:Npn \nwpu@set@school #1
  { \cs_gset:Npn \nwpu@chs@school {#1} }
\cs_new_protected:Npn \nwpu@set@chs@major #1
  { \cs_gset:Npn \nwpu@chs@major {#1} }
\cs_new_protected:Npn \nwpu@set@eng@major #1
  { \cs_gset:Npn \nwpu@eng@major {#1} }
\cs_new_protected:Npn \nwpu@set@chs@advisor #1
  { \cs_gset:Npn \nwpu@chs@advisor { \blindreview{#1} } }
\cs_new_protected:Npn \nwpu@set@eng@advisor #1
  { \cs_gset:Npn \nwpu@eng@advisor { \blindreview{#1} } }
\cs_new_protected:Npn \nwpu@set@chs@advisor@rank #1
  { \cs_gset:Npn \nwpu@chs@advisorAcademicRank { \nobreakspace\nobreakspace #1 } }
\cs_new_protected:Npn \nwpu@set@eng@advisor@rank #1
  { \cs_gset:Npn \nwpu@eng@advisorAcademicRank {#1} }
\cs_new_protected:Npn \nwpu@set@chs@funding #1
  { \cs_gset:Npn \nwpu@chs@funding {#1} }
\cs_new_protected:Npn \nwpu@set@eng@funding #1
  { \cs_gset:Npn \nwpu@eng@funding {#1} }
\cs_new_protected:Npn \nwpu@set@chs@schoolname #1
  { \cs_gset:Npn \nwpu@chs@schoolname {#1} }
\cs_new_protected:Npn \nwpu@set@eng@schoolname #1
  { \cs_gset:Npn \nwpu@eng@schoolname {#1} }
\cs_new_protected:Npn \nwpu@set@studentnumber #1
  { \cs_gset:Npn \nwpu@uid { \blindreview{#1} } }
\cs_new_protected:Npn \nwpu@set@schoolcode #1
  { \cs_gset:Npn \nwpu@schoolcode {#1} }
\cs_new_protected:Npn \nwpu@set@classnumber #1
  { \cs_gset:Npn \nwpu@classnumber {#1} }
\cs_new_protected:Npn \nwpu@set@securitylevel #1
  { \cs_gset:Npn \nwpu@securitylevel {#1} }
%%-----------------------------------------------------------------------------%
\DeclareKeys [ nwputhesis ]
  {
    title                 .code:n = \nwpu@set@chs@title {#1},
    cover-title-line-1    .code:n = \nwpu@set@chs@cover@title@line@a {#1},
    cover-title-line1     .code:n = \nwpu@set@chs@cover@title@line@a {#1},
    cover-title-line-a    .code:n = \nwpu@set@chs@cover@title@line@a {#1},
    cover-title-line-2    .code:n = \nwpu@set@chs@cover@title@line@b {#1},
    cover-title-line2     .code:n = \nwpu@set@chs@cover@title@line@b {#1},
    cover-title-line-b    .code:n = \nwpu@set@chs@cover@title@line@b {#1},
    title*                .code:n = \nwpu@set@eng@title {#1},
    title-en              .code:n = \nwpu@set@eng@title {#1},
    author                .code:n = \nwpu@set@chs@author {#1},
    author*               .code:n = \nwpu@set@eng@author {#1},
    author-en             .code:n = \nwpu@set@eng@author {#1},
    date                  .code:n = \nwpu@set@chs@date {#1},
    date*                 .code:n = \nwpu@set@eng@date {#1},
    date-en               .code:n = \nwpu@set@eng@date {#1},
    year                  .code:n = \nwpu@set@year {#1},
    month                 .code:n = \nwpu@set@month {#1},
    school                .code:n = \nwpu@set@school {#1},
    major                 .code:n = \nwpu@set@chs@major {#1},
    major*                .code:n = \nwpu@set@eng@major {#1},
    major-en              .code:n = \nwpu@set@eng@major {#1},
    advisor               .code:n = \nwpu@set@chs@advisor {#1},
    advisor*              .code:n = \nwpu@set@eng@advisor {#1},
    advisor-en            .code:n = \nwpu@set@eng@advisor {#1},
    advisor-rank          .code:n = \nwpu@set@chs@advisor@rank {#1},
    advisor-rank*         .code:n = \nwpu@set@eng@advisor@rank {#1},
    advisor-rank-en       .code:n = \nwpu@set@eng@advisor@rank {#1},
    advisor-title         .code:n = \nwpu@set@chs@advisor@rank {#1},
    advisor-title*        .code:n = \nwpu@set@eng@advisor@rank {#1},
    advisor-title-en      .code:n = \nwpu@set@eng@advisor@rank {#1},
    funding               .code:n = \nwpu@set@chs@funding {#1},
    funding*              .code:n = \nwpu@set@eng@funding {#1},
    funding-en            .code:n = \nwpu@set@eng@funding {#1},
    school-name           .code:n = \nwpu@set@chs@schoolname {#1},
    school-name*          .code:n = \nwpu@set@eng@schoolname {#1},
    school-name-en        .code:n = \nwpu@set@eng@schoolname {#1},
    student-number        .code:n = \nwpu@set@studentnumber {#1},
    studentnumber         .code:n = \nwpu@set@studentnumber {#1},
    school-code           .code:n = \nwpu@set@schoolcode {#1},
    schoolcode            .code:n = \nwpu@set@schoolcode {#1},
    class-number          .code:n = \nwpu@set@classnumber {#1},
    classnumber           .code:n = \nwpu@set@classnumber {#1},
    security-level        .code:n = \nwpu@set@securitylevel {#1},
    securitylevel         .code:n = \nwpu@set@securitylevel {#1},
  }
\NewDocumentCommand \nwputhesissetup { m }
  {
    \bool_set_true:N \l__nwpu_in_setup_bool
    \SetKeys [ nwputhesis ] {#1}
    \bool_set_false:N \l__nwpu_in_setup_bool
  }
\ExplSyntaxOff
