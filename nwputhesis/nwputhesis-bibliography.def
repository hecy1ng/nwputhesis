%% This file is part of nwputhesis.
%% It is loaded internally by nwputhesis.cls.

%% 参考文献处理
%%-----------------------------------------------------------------------------%
\ExplSyntaxOn
% 中文全角标点支持（gb7714-2025 提供，此处为 gb7714-2015 提供降级）
\cs_if_exist:cF { gbpunctcomma } { \cs_new:Npn \gbpunctcomma { \addcomma\addspace } }
\cs_if_exist:cF { gbpunctcommalanen } { \cs_new:Npn \gbpunctcommalanen { \addcomma\addspace } }
\cs_if_exist:cF { gbpunctcolon } { \cs_new:Npn \gbpunctcolon { \addcolon\addspace } }
\cs_if_exist:cF { gbpunctcolonlanen } { \cs_new:Npn \gbpunctcolonlanen { \addcolon\addspace } }
\cs_if_exist:cF { gbpunctdot } { \cs_new:Npn \gbpunctdot { \adddot\addspace } }
\cs_if_exist:cF { gbpunctdotlanen } { \cs_new:Npn \gbpunctdotlanen { \adddot\addspace } }
\cs_new:Npn \nwpucolon { \iffieldequalstr{userd}{chinese}{\gbpunctcolon}{\gbpunctcolonlanen} }
\cs_new:Npn \nwp comma { \iffieldequalstr{userd}{chinese}{\gbpunctcomma}{\gbpunctcommalanen} }
\cs_new:Npn \nwpudot { \iffieldequalstr{userd}{chinese}{\gbpunctdot}{\gbpunctdotlanen} }
\renewcommand*{\bibfont}{\nwpuBodyFont}
\str_if_eq:VnF \l__nwpu_bibindent_tl { hanging } {
    \dim_set:Nn \biblabelsep { \nwpuBibLabelSep }
}
\dim_new:N \l__nwpu_bib_firstline_indent_dim
\dim_set:Nn \l__nwpu_bib_firstline_indent_dim { 24pt }
\dim_new:N \l__nwpu_bib_label_dim
\dim_new:N \l__nwpu_bib_firstline_reserve_dim
\dim_set:Nn \l__nwpu_bib_firstline_reserve_dim { \nwpuBibFirstLineReserve }%
\tl_new:N \l__nwpu_patent_number_tl
\cs_new_protected:Npn \nwpu_patent_number_allowbreaks:n #1
  {
    \tl_set:Nn \l__nwpu_patent_number_tl {#1}
    \regex_replace_all:nnN {([A-Za-z])([0-9])} {\1\c{allowbreak}\2} \l__nwpu_patent_number_tl
    \regex_replace_all:nnN {([0-9])([A-Za-z])} {\1\c{allowbreak}\2} \l__nwpu_patent_number_tl
    \tl_use:N \l__nwpu_patent_number_tl
  }
\cs_new_protected:Npn \nwpuPatentNumberAllowBreaks #1
  {
    \nwpu_patent_number_allowbreaks:n {#1}
  }
\DeclareFieldFormat[patent]{title}{#1}
\DeclareFieldFormat[patent]{number}{\nwpuPatentNumberAllowBreaks{#1}}
\renewcommand*{\multiciterangedelim}{\textasciitilde}
\renewcommand*{\multicitesubentryrangedelim}{\multiciterangedelim}
\renewcommand*{\superciterangedelim}{\textasciitilde}
\renewcommand*{\supercitesubentryrangedelim}{\superciterangedelim}
\renewbibmacro*{title}{%
\ifboolexpr{%
    test{\iffieldundef{title}}%
    and
    test{\iffieldundef{subtitle}}}%
    {}%
    {\printtext[title]{\bibtitlefont%
       \iffieldequalstr{entrysubtype}{standard}{%
            \iffieldundef{number}{}{\printtext{\thefield{number}}\setunit{\nwp comma}}%
       }{}%
       \printfield[titlecase]{title}%
       \ifboolexpr{test {\iffieldundef{subtitle}}}%
            {}{\setunit{\subtitlepunct}\printfield[titlecase]{subtitle}}%
       \iffieldundef{titleaddon}{}{\setunit{\subtitlepunct}\printfield{titleaddon}}%
       \ifboolexpr{test{\ifentrytype{book}} and (not test{\iffieldundef{volume}})}%
            {\setunit{\subtitlepunct}\printfield{volume}}{}%
       \ifboolexpr{(test{\ifentrytype{archive}} or  test{\ifentrytype{online}}) and (not test{\iffieldundef{number}})}%
            {\setunit{\subtitlepunct}\printfield{number}}{}%
       \iftoggle{bbx:gbtype}%
            {\iffieldundef{entrysubtype}{\printfield[gbtypeflag]{usera}}%
            {\iffieldequalstr{entrysubtype}{standard}{\printfield[gbtypeflags]{usera}}%
                  {\iffieldequalstr{entrysubtype}{news}{\printfield[gbtypeflagn]{usera}}%
                  {\printfield[gbtypeflag]{usera}}}}}{}%
       }%
    }%
}
\DeclareBibliographyDriver{patent}{%
    \usebibmacro{bibindex}%
    \usebibmacro{begentry}%
    \usebibmacro{author/translator+others}%
    \ifnameundef{author}{}{\setunit{\labelnamepunct}\newblock}%
    \printtext[title]{\bibtitlefont\printfield[titlecase]{title}}%
    \mbox{[P]}%
    \newunit\newblock%
    \printlist{location}%
    \iffieldundef{number}{}{%
        \setunit{\nwpucolon}%
        \printfield{number}%
    }%
    \ifboolexpr{
        not test {\iffieldundef{year}}
        or
        not test {\iffieldundef{month}}
        or
        not test {\iffieldundef{day}}
    }{%
        \setunit{\nwp comma}%
        \usebibmacro{newsdate}%
    }{}%
    \usebibmacro{finentry}%
}
\newbibmacro*{nwpu:miscfullinstitution+location+date}{%
  \bibpubfont%
  \iflistundef{institution}
    {}
    {\printlist{institution}\setunit*{\nwpudot}}%
  {\printlist{location}%
   \iflistundef{location}
     {}
     {\iflistundef{institution}
        {\setunit*{\nwpudot}}
        {\setunit*{\nwpucolon}}}%
   \ifboolexpr{
        not test {\iffieldundef{year}}
        or
        not test {\iffieldundef{month}}
        or
        not test {\iffieldundef{day}}
   }
     {\usebibmacro{newsdate}}
     {}}}
\DeclareBibliographyDriver{misc}{%
  \usebibmacro{bibindex}%
  \usebibmacro{begentry}%
  \usebibmacro{author/editor+others/translator+others}%
  \ifnameundef{namea}{}{\setunit{\labelnamepunct}\newblock}%
  \usebibmacro{title}%
  \iftoggle{bbx:gbstrict}{}{%
    \newunit
    \printlist{language}%
    \newunit\newblock
    \usebibmacro{byauthor}%
    \newunit\newblock
    \usebibmacro{byeditor+others}}%
  \newunit\newblock
  \printfield{howpublished}%
  \newunit\newblock
  \printfield{type}%
  \newunit
  \printfield{version}%
  \newunit
  \printfield{note}%
  \newunit\newblock
  \usebibmacro{nwpu:miscfullinstitution+location+date}%
  \usebibmacro{chapter+pages}%
  \usebibmacro{doi+eprint+url}%
  \newunit\newblock
  \usebibmacro{addendum+pubstate}%
  \setunit{\bibpagerefpunct}\newblock
  \usebibmacro{pageref}%
  \newunit\newblock
  \iftoggle{bbx:related}
    {\usebibmacro{related:init}\usebibmacro{related}}
    {}%
  \usebibmacro{annotation}\usebibmacro{finentry}}
\newbibmacro*{nwpu:standardlocation+publisher+date}{%
  \bibpubfont%
  \iflistundef{location}{}{%
    \printlist{location}%
    \iflistundef{publisher}{}{\setunit*{\nwpucolon}}%
  }%
  \iflistundef{publisher}{}{\printlist{publisher}}%
  \ifboolexpr{
      not test {\iffieldundef{year}}
      or
      not test {\iffieldundef{month}}
      or
      not test {\iffieldundef{day}}
  }{
    \setunit*{\nwp comma}%
    \usebibmacro{newsdate}%
  }{}%
}
\DeclareBibliographyDriver{standard}{%
  \usebibmacro{bibindex}%
  \usebibmacro{begentry}%
  \usebibmacro{author/translator+others}%
  \ifnameundef{author}{}{\setunit{\labelnamepunct}\newblock}%
  \usebibmacro{title}%
  \newunit\newblock
  \usebibmacro{nwpu:standardlocation+publisher+date}%
  \usebibmacro{chapter+pages}%
  \usebibmacro{doi+eprint+url}%
  \newunit\newblock
  \usebibmacro{addendum+pubstate}%
  \setunit{\bibpagerefpunct}\newblock
  \usebibmacro{pageref}%
  \newunit\newblock
  \iftoggle{bbx:related}
    {\usebibmacro{related:init}\usebibmacro{related}}
    {}%
  \usebibmacro{annotation}\usebibmacro{finentry}%
}
\newbibmacro*{nwpu:otherdate}{%
  \iffieldundef{year}
    {}
    {\thefield{year}%
     \iffieldundef{month}
       {}
       {-\ifnum\thefield{month}<10 0\fi\thefield{month}%
        \iffieldundef{day}
          {}
          {-\ifnum\thefield{day}<10 0\fi\thefield{day}}}}%
}
\newbibmacro*{nwpu:otherurldate}{%
  \iffieldundef{urlyear}
    {}
    {\thefield{urlyear}%
     \iffieldundef{urlmonth}
       {}
       {-\ifnum\thefield{urlmonth}<10 0\fi\thefield{urlmonth}%
        \iffieldundef{urlday}
          {}
          {-\ifnum\thefield{urlday}<10 0\fi\thefield{urlday}}}}%
}
\newbibmacro*{nwpu:otherdate+urldate}{%
  \ifboolexpr{
      test {\iffieldundef{year}}
      and
      test {\iffieldundef{urlyear}}
  }{}{%
    \printtext{%
      \begingroup
      \xeCJKsetup{CJKecglue={}}%
      \usebibmacro{nwpu:otherdate}%
      \ifboolexpr{
          test {\iffieldundef{year}}
          and
          test {\iffieldundef{month}}
          and
          test {\iffieldundef{day}}
      }{}{\iffieldundef{urlyear}{}{／}}%
      \usebibmacro{nwpu:otherurldate}%
      \endgroup
    }%
  }%
}
\DeclareBibliographyDriver{other}{%
  \usebibmacro{bibindex}%
  \usebibmacro{begentry}%
  \usebibmacro{author/editor+others/translator+others}%
  \ifnameundef{namea}{}{\setunit{\labelnamepunct}\newblock}%
  \usebibmacro{title}%
  \iftoggle{bbx:gbstrict}{}{%
    \newunit
    \printlist{language}%
    \newunit\newblock
    \usebibmacro{byauthor}%
    \newunit\newblock
    \usebibmacro{byeditor+others}}%
  \newunit\newblock
  \printfield{howpublished}%
  \newunit\newblock
  \printfield{type}%
  \newunit
  \printfield{version}%
  \newunit
  \printfield{note}%
  \newunit\newblock
  \usebibmacro{nwpu:otherdate+urldate}%
  \usebibmacro{chapter+pages}%
  \newunit\newblock
  \printfield{url}%
  \newunit\newblock
  \usebibmacro{addendum+pubstate}%
  \setunit{\bibpagerefpunct}\newblock
  \usebibmacro{pageref}%
  \newunit\newblock
  \iftoggle{bbx:related}
    {\usebibmacro{related:init}\usebibmacro{related}}
    {}%
  \usebibmacro{annotation}\usebibmacro{finentry}}
\nwpu_if_bachelor:TF{%
    \DeclareStyleSourcemap{
        \maps[datatype=bibtex]{
            \map{
                \step[fieldsource=journal, fieldtarget=journaltitle]
            }
            \map[overwrite]{
                \pertype{conference}
                \step[fieldset=usera, fieldvalue={A}]
            }
            \map[overwrite]{
                \pertype{inproceedings}
                \step[fieldset=usera, fieldvalue={A}]
            }
        }
    }
    \DeclareDriverSourcemap[datatype=bibtex]{
        \map{
            \step[typesource=conference, typetarget=nwpubachelorconf]
        }
        \map{
            \step[typesource=inproceedings, typetarget=nwpubachelorconf]
        }
    }
    \DeclareFieldFormat[nwpubachelorconf]{title}{#1}
    \DeclareFieldFormat[nwpubachelorconf]{booktitle}{#1}
    \DeclareFieldFormat[nwpubachelorconf]{volume}{#1}
    \newbibmacro*{nwpu:bachelorconfvolume}{%
        \iffieldundef{volume}
            {}
            {%
                \iffieldequalstr{userd}{chinese}
                    {：第~\printfield{volume}~卷}
                    {\addcolon\space vol.\space\printfield{volume}}%
            }%
    }
    \newbibmacro*{nwpu:bachelorbooktitle}{%
        \ifboolexpr{
            test {\iffieldundef{booktitle}}
            and
            test {\iffieldundef{booksubtitle}}
        }
            {}
            {\printtext[booktitle]{\bibtitlefont%
                \printfield[booktitlecase]{booktitle}%
                \iffieldundef{booksubtitle}{}{\setunit{\subtitlepunct}\printfield[booktitlecase]{booksubtitle}}%
                \usebibmacro{nwpu:bachelorconfvolume}%
                \printtext{[C]}%
            }}%
    }
    \newbibmacro*{nwpu:bachelorin}{%
        \setunit{\nwpudot}%
        \iffieldequalstr{userd}{chinese}
            {\printtext{见；}}
            {\printtext{In\addsemicolon\space}}%
    }
    \DeclareBibliographyDriver{nwpubachelorconf}{%
        \usebibmacro{bibindex}%
        \usebibmacro{begentry}%
        \usebibmacro{author/translator+others}%
        \ifnameundef{author}{}{\setunit{\labelnamepunct}\newblock}%
        \usebibmacro{title}%
        \usebibmacro{nwpu:bachelorin}%
        \usebibmacro{bybookauthor}%
        \ifnameundef{bookauthor}{%
            \ifnameundef{editor}{}{\newunit}%
        }{\newunit}%
        \iffieldundef{series}{}{\usebibmacro{series+number}\setunit{\nwpucolon}}%
        \usebibmacro{nwpu:bachelorbooktitle}%
        % \iffieldundef{volume}{}{\setunit{\nwpucolon}\printfield{volume}}%
        \iffieldundef{number}{}{\setunit{\nwpucolon}\printfield{number}}%
        \newunit\newblock%
        \printfield{edition}%
        \newunit\newblock%
        \usebibmacro{publisher+location+date}%
        \usebibmacro{chapter+pages}%
        \usebibmacro{doi+eprint+url}%
        \newunit\newblock%
        \iftoggle{bbx:isbn}
            {\printfield{isbn}}
            {}%
        \newunit\newblock%
        \usebibmacro{addendum+pubstate}%
        \setunit{\bibpagerefpunct}\newblock%
        \usebibmacro{pageref}%
        \newunit\newblock%
        \iftoggle{bbx:related}
            {\usebibmacro{related:init}\usebibmacro{related}}
            {}%
        \usebibmacro{annotation}\usebibmacro{finentry}%
    }
}{}
\ExplSyntaxOff
\ExplSyntaxOn
\cs_new_protected:Npn \nwpu@bibitemcmd {%
    \addvspace{\bibitemsep}%
    \leavevmode
    \str_case:Vn \l__nwpu_bibindent_tl
      {
        { auto } {
          \nwpu_if_bachelor:TF
            { \hspace*{0pt} }
            { \hspace*{\l__nwpu_bib_firstline_indent_dim} }
        }
        { firstline } { \hspace*{\l__nwpu_bib_firstline_indent_dim} }
        { none }      { \hspace*{0pt} }
      }
    \mkgbnumlabel{\printfield{labelnumber}}\hspace{\nwpuBibLabelNumberGap}}
% hanging 模式不覆盖环境，使用 gb7714-2015 默认的 list 环境
\str_if_eq:VnF \l__nwpu_bibindent_tl { hanging } {
    \defbibenvironment{bibliography}
        {\begingroup\setlength{\parindent}{\nwpuBibParIndent}\setlength{\emergencystretch}{\nwpuBibEmergencyStretch}\sloppy}
        {\endgroup}
        {\nwpu@bibitemcmd}
}
\AtBeginBibliography{                                        %
    \nwpuBodyFont                                           %
    \str_if_eq:VnF \l__nwpu_bibindent_tl { hanging } {
        \setlength{\bibitemsep}{\nwpuBibItemSep}                %
    }
}                                                           %
\cs_set_eq:NN \nwpu@oldprintbibliography \printbibliography            %
\RenewDocumentCommand{\printbibliography}{O{}}{             %
    \cleardoublepage                                        %
    \nwpu@oldprintbibliography[                             %
        heading=bibintoc,                                   %
        title={参考文献},                                     %
        #1                                                  %
    ]                                                       %
    \cleardoublepage                                        %
}                                                           %
\DeclareBibliographyCategory{accomplishments}
\clist_new:N \l__nwpu_pub_keys_clist
\NewDocumentCommand{\addpub}{m}{%
    \clist_put_right:Nn \l__nwpu_pub_keys_clist {#1}%
}
\NewDocumentCommand{\printaccomplishments}{}{%
    \begin{accomplishments}
    \begin{refsection}
        \clist_map_inline:Nn \l__nwpu_pub_keys_clist {\nocite{##1}}%
        \nwpu@oldprintbibliography[heading=none]%
    \end{refsection}
    \end{accomplishments}
}
\ExplSyntaxOff
