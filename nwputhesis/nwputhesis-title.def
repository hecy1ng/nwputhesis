%% This file is part of nwputhesis.
%% It is loaded internally by nwputhesis.cls.

\ExplSyntaxOn
\box_new:N \l__nwpu_title_box
\box_new:N \l__nwpu_underline_box
%%-----------------------------------------------------------------------------%
%% 模块级长度变量（由封面页和内封页共享）
%%-----------------------------------------------------------------------------%
\dim_new:N \l__nwpu_coverpage_detail_dim
\dim_new:N \l__nwpu_chstitle_hwidtha_dim
\dim_new:N \l__nwpu_chstitle_hwidthb_dim
\dim_new:N \l__nwpu_author_dim
\dim_new:N \l__nwpu_advisor_dim
\dim_new:N \l__nwpu_maxname_dim
\int_new:N \l__nwpu_hbadness_save_int
\int_new:N \l__nwpu_vbadness_save_int

%% 封皮页
%%-----------------------------------------------------------------------------%
\cs_new_protected:Npn \make@nwpu@coverpage {                          % 设置封皮页
    \thispagestyle{empty}                                   % 清空页面格式
    \settowidth{\l__nwpu_coverpage_detail_dim}{\sSanhao 申请学位日期}
    \begin{titlepage}                                       %
        % 彩色封面背景图
        \nwpu_if_colorcover:TF {
            \begin{tikzpicture}[remember picture,overlay]
                \node[at=(current page.center),inner sep=0pt] {
                    \nwpu_if_phd:TF {
                        \includegraphics[width=\paperwidth,height=\paperheight]{cover-phd.jpg}
                    } {
                        \nwpu_if_bachelor:TF {
                            \includegraphics[width=\paperwidth,height=\paperheight]{cover-bachelor.jpg}
                        } {
                            \nwpu_if_academic:TF {
                                \includegraphics[width=\paperwidth,height=\paperheight]{cover-master-academic.jpg}
                            } {
                                \includegraphics[width=\paperwidth,height=\paperheight]{cover-master-professional.jpg}
                            }
                        }
                    }
                };
            \end{tikzpicture}
        }
        \bfseries                                           %
        \linespread{1.25}\selectfont                        % 1.25 倍行距
        \begin{center}                                      %
            \hfill \fHei \sWuhao                            %
            \begin{tabular}{|>{\centering\arraybackslash}p{2.05cm}|>{\centering\arraybackslash}p{2.4cm}|}\hline %
                \makebox[4em][s]{学\hfil 校\hfil 代\hfil 码} & \nwpu@schoolcode    \\ \hline
                \makebox[4em][s]{分\hfil 类\hfil 号}          & \nwpu@classnumber   \\ \hline
                \makebox[4em][s]{密\hfil 级}                  & \nwpu@securitylevel \\ \hline
                \makebox[4em][s]{学\hfil 号}                  & \nwpu@uid           \\ \hline
            \end{tabular}\par                               % 排版基本信息表
            \vspace{21\baselineskip}                        % 21 * 10.5pt * 1.25
            \fHei \sErhao
            \begin{tabular}[t]{>{\centering\arraybackslash}p{2.34cm}p{12.13cm}}
                \begin{minipage}[c][1.45cm][c]{2.34cm}\centering 题目\end{minipage}
                & \begin{minipage}[c][1.45cm][c]{12.13cm}\centering\nwpu@chs@coverTitleLineA\par\end{minipage} \tabularnewline
                \cline{2-2}
                & \begin{minipage}[c][1.45cm][c]{12.13cm}\centering\nwpu@chs@coverTitleLineB\par\end{minipage} \tabularnewline
                \cline{2-2}
            \end{tabular}\par                                   % 排版结束
            \sWuhao \vspace{3\baselineskip}                 % 2 * 10.5pt * 1.25
            \sSanhao \fSong                                 %
            \begin{tabular}[t]{>{\centering\arraybackslash}p{1.56cm}p{3.72cm}}
                \begin{minipage}[c][1.28cm][c]{1.56cm}\centering\bf 作者\end{minipage}
                & \begin{minipage}[c][1.28cm][c]{3.72cm}\centering\bf\nwpu@chs@author\par\end{minipage} \tabularnewline
                \cline{2-2}
            \end{tabular}\par                               % 排版作者信息
            \sWuhao \vspace{4\baselineskip}                 % 3 * 10.5pt * 1.25
            \sSanhao \fSong
            \begin{tabular}[t]{>{\centering\arraybackslash}p{3.59cm}p{9cm}}
                \begin{minipage}[c][1cm][c]{3.59cm}\centering\bf \nwpu@chs@outerCoverFirstOption\end{minipage}
                & \begin{minipage}[c][1cm][c]{9cm}\centering\bf\nwpu@chs@major\par\end{minipage} \tabularnewline
                \cline{2-2}
                \begin{minipage}[c][1cm][c]{3.59cm}\centering\bf 指{\enspace}导{\enspace}教{\enspace}师\end{minipage}
                & \begin{minipage}[c][1cm][c]{9cm}\centering\bf\nwpu@chs@advisor\nwpu@chs@advisorAcademicRank\par\end{minipage} \tabularnewline
                \cline{2-2}
                \begin{minipage}[c][1cm][c]{3.59cm}\centering\bf 培{\enspace}养{\enspace}单{\enspace}位\end{minipage}
                & \begin{minipage}[c][1cm][c]{9cm}\centering\bf\nwpu@chs@school\par\end{minipage} \tabularnewline
                \cline{2-2}
                \begin{minipage}[c][1cm][c]{3.59cm}\centering\bf 申{\enspace}请{\enspace}日{\enspace}期\end{minipage}
                & \begin{minipage}[c][1cm][c]{9cm}\centering\bf\nwpu@chs@date\par\end{minipage} \tabularnewline
                \cline{2-2}
            \end{tabular}                                   % 排版结束
            \vspace{2.5\baselineskip}                       % 2.5 * 24pt * 1.25
        \end{center}                                        %
    \end{titlepage} \fSong \normalsize \newpage \clearpage  %
}                                                           %
%%-----------------------------------------------------------------------------%
%% 中文内封
%%-----------------------------------------------------------------------------%
\cs_new_protected:Npn \make@nwpu@chs@title {                          % 设置中文内封
    \thispagestyle{empty}                                   % 清空页面格式
    \settowidth{\l__nwpu_chstitle_hwidtha_dim}{\sSanhao\nwpu@chs@schoolname}
    \settowidth{\l__nwpu_chstitle_hwidthb_dim}{\sYihao\nwpu@chs@doctitle}
    % 测量宽度（注意使用相同字体 \sSanhao）
    \settowidth{\l__nwpu_author_dim}{\sSanhao\nwpu@chs@author}
    \settowidth{\l__nwpu_advisor_dim}{\sSanhao\nwpu@chs@advisor}
    % 取最大值
    \dim_set:Nn \l__nwpu_maxname_dim { \l__nwpu_author_dim }
    \dim_compare:nNnT \l__nwpu_advisor_dim > \l__nwpu_maxname_dim
        { \dim_set:Nn \l__nwpu_maxname_dim { \l__nwpu_advisor_dim } }
    \begin{titlepage}                                       %
        \linespread{1.4}\selectfont                         %
        \begin{center}                                      %
            \fSong \sSanhao \par \vspace*{1\baselineskip}   %
            \makebox[1.41667\l__nwpu_chstitle_hwidtha_dim][s]{\sSanhao\nwpu@chs@schoolname} \par
            \vspace*{5mm}                                   %
            \makebox[1.41667\l__nwpu_chstitle_hwidthb_dim][s]{\sYihao\nwpu@chs@doctitle} \par
            \vspace*{5mm}                                   %
            \sSihao \par \vspace{6\baselineskip}            % 6 * 21pt * 1.5
            \fSong \sErhao                                  % 排版标题
            \begin{minipage}[t]{2cm} \hfill {题目：} \\ \end{minipage}
            \hbox_set:Nn \l__nwpu_title_box {                    %
                \begin{minipage}[t]{12cm}                   %
                    \begin{center} \nwpu@chs@title \end{center}
                \end{minipage}                              %
            }                                               %
            \hbox_set:Nn \l__nwpu_underline_box {                 %
                \begin{minipage}[t]{12cm}                   %
                    \begin{center}                          %
                        \uline{\hfill\quad\hfill} \\        %
                        \uline{\hfill\quad\hfill} \\        %
                    \end{center}                            %
                \end{minipage}                              %
            }                                               %
            \hspace{-1cm}                                   %
            \box_use:N \l__nwpu_title_box \kern -\box_wd:N \l__nwpu_title_box \box_use_drop:N \l__nwpu_underline_box \fSong \sWuhao \par % 排版结束
            \vspace{6\baselineskip}                         % 7 * 10.5pt * 1.5
            \sSanhao \nwpu@chs@innerCoverFirstOption：\coverunderline[5.5cm]{\nwpu@chs@major} \\
            \sSanhao 作{\qquad}者：\coverunderline[5.5cm]{\makebox[\l__nwpu_maxname_dim][s]{\nwpu@chs@author}} \\
            \sSanhao 指导教师：\coverunderline[5.5cm]{\makebox[\l__nwpu_maxname_dim][s]{\nwpu@chs@advisor}} \\
            \fSong \sWuhao \par                             %
            \vspace{2\baselineskip}                         % 2 * 10.5pt * 1.5
            \fSong \sSanhao \nwpu@chs@date                  %
        \end{center}                                        %
    \end{titlepage} \fSong \normalsize \newpage \clearpage  %
}                                                           %
%%-----------------------------------------------------------------------------%
%% 英文内封
%%-----------------------------------------------------------------------------%
\cs_new_protected:Npn \make@nwpu@eng@title {                          % 设置英文内封
    \thispagestyle{empty}                                   % 清空页面格式
    \begin{titlepage}                                       %
        \begin{center}                                      %
            \fSong \sErhao \par \vspace*{3\baselineskip}    %
            \fEng \sErhao \textbf{Title:} \sSanhao \nwpu@eng@title \par     %
            \fSong \sXiaoer \vspace{3\baselineskip}         %
            \fEng \sXiaosan \textbf{By} \par                %
            \fEng \sXiaosan \nwpu@eng@author \par  %
            \fEng \sXiaosan \textbf{Under~the~Supervision~of~\nwpu@eng@advisorAcademicRank} \\
            \fEng \sXiaosan \nwpu@eng@advisor \par %
            \fSong \sSanhao \vspace{4\baselineskip}         %
            \fEng \sXiaosan A~Dissertation~Submitted~to \\  %
            \fEng \sXiaosan {\nwpu@eng@schoolname} \\       %
            \fSong \sSanhao \vspace{1\baselineskip}         %
            \fEng \sXiaosan {In~Partial~Fulfillment~of~The~Requirement} \\
            \fEng \sXiaosan {For~The~Degree~of} \\                      %
            \fEng \sXiaosan {{\nwpu@eng@degree}~of~\nwpu_if_master:TF{\nwpu@eng@major}{\textbf{\nwpu@eng@major}}}
            \fSong \sXiaosan \par \vspace{4\baselineskip}   %
            \fEng \sXiaosan Xi'an,~P.R.~China \\            %
            \fEng \sXiaosan {\nwpu@eng@date}                %
        \end{center}                                        %
    \end{titlepage} \fSong \normalsize \newpage             %
    \thispagestyle{empty} \cleardoublepage                  %
}                                                           %
%%-----------------------------------------------------------------------------%
%% 本科封面
%%-----------------------------------------------------------------------------%
\cs_new_protected:Npn \make@nwpu@bachelor@cover {                       % 设置本科封面
    \thispagestyle{empty}                                   % 清空页面格式
    \begin{titlepage}                                       %
        \begin{center}                                      %
            \vspace*{2.3cm}                                 %
            \includegraphics[width=10cm]{nwpulogo.png}%
            \vskip 1.3cm                                    %
            \sChuhao\fSong {\bfseries 本科毕业设计（论文）}   %
            \vskip 3.5cm                                    %
                {                                               %
                    \sSanhao\fHei 题~~目 \hspace{0.2cm}\coverunderline[8cm]{\nwpu@chs@title} %
                }                                               %
            \vskip 1.5cm                                    %
                {                                               %
                    \sSihao\fSong 专业名称\coverunderline[5.5cm]{\nwpu@chs@major} %
                    \vskip 1.1cm                                %
                    \sSihao\fSong 学生姓名\coverunderline[5.5cm]{\nwpu@chs@author} %
                    \vskip 1.1cm                                %
                    \sSihao\fSong 指导教师\coverunderline[5.5cm]{\nwpu@chs@advisor} %
                    \vskip 1.1cm                                %
                    \sSihao\fSong 毕业时间\coverunderline[5.5cm]{\nwpu@chs@date} %
                    \vfill                                      %
                }                                               %
        \end{center}                                        %
    \end{titlepage} \fSong \normalsize \newpage \clearpage  %
}                                                           %
%%-----------------------------------------------------------------------------%
%% 生成标题页
%%-----------------------------------------------------------------------------%
\cs_gset_protected:Npn \maketitle {
    \int_set:Nn \l__nwpu_hbadness_save_int { \hbadness }
    \int_set:Nn \l__nwpu_vbadness_save_int { \vbadness }
    \hbadness=10000
    \vbadness=10000
    \nwpu_if_bachelor:TF {                                      % 本科封面
        \make@nwpu@bachelor@cover                           %
    } {                                                      % 硕博封面
        \make@nwpu@coverpage                                % 封皮页
        \make@nwpu@chs@title                                % 中文内封
        \make@nwpu@eng@title                                % 英文内封
    }
    \hbadness=\l__nwpu_hbadness_save_int
    \vbadness=\l__nwpu_vbadness_save_int
}                                                           %
%%-----------------------------------------------------------------------------%
%% 彩色封底
%%-----------------------------------------------------------------------------%
\cs_new_protected:Npn \make@nwpu@backcover {                          % 彩色封底
    \nwpu_if_colorcover:TF {
        \clearpage
        \thispagestyle{empty}
        \begin{tikzpicture}[remember picture,overlay]
            \node[at=(current page.center),inner sep=0pt] {
                \nwpu_if_phd:TF {
                    \includegraphics[width=\paperwidth,height=\paperheight]{backcover-phd.jpg}
                } {
                    \nwpu_if_bachelor:TF {
                        \includegraphics[width=\paperwidth,height=\paperheight]{backcover-bachelor.jpg}
                    } {
                        \nwpu_if_academic:TF {
                            \includegraphics[width=\paperwidth,height=\paperheight]{backcover-master-academic.jpg}
                        } {
                            \includegraphics[width=\paperwidth,height=\paperheight]{backcover-master-professional.jpg}
                        }
                    }
                }
            };
        \end{tikzpicture}
    }
}
\AtEndDocument{\make@nwpu@backcover}                        % 在文档末尾自动插入封底                                                           %
%%=============================================================================%
%%=============================================================================%
%% 学位论文评阅人和答辩委员会名单
%%-----------------------------------------------------------------------------%
%%-----------------------------------------------------------------------------%
\cs_new_protected:Npn \npu@text #1 {\relax\sDefault{#1}}
\cs_new_protected:Npn \expert #1 #2 #3 {\npu@text{#1} & \npu@text{#2} & \npu@text{#3} \\ }
\cs_new_protected:Npn \expertBlindReview {\expert{全盲评阅}{无}{无}}
\cs_new_protected:Npn \expertEmpty {\expert{}{}{}}
\cs_new_protected:Npn \fullBlindReview #1 {%
    \prg_replicate:nn {#1} {\expertBlindReview}%
    \prg_replicate:nn { \int_max:nn { 5 - #1 } { 0 } } {\expertEmpty}%
}
\cs_new_protected:Npn \defenseDate #1 {\sDefault\textbf{答辩日期}%
    & \multicolumn{3}{c}{\sDefault{#1}} \\ }
\cs_new_protected:Npn \defenseChair #1 #2 #3 {\sDefault\textbf{主席} & \expert{#1}{#2}{#3} }
\cs_new_protected:Npn \committeeMember #1 #2 #3 {\sDefault\textbf{委员} & \expert{#1}{#2}{#3} }
\cs_new_protected:Npn \defenseSecretary #1 #2 #3 {\sDefault\textbf{秘书} & \expert{#1}{#2}{#3} }
%%-----------------------------------------------------------------------------%
\cs_new_protected:Npn \makeCommitteePage #1 {                         %
    \thispagestyle{empty}                                   % 清空页面格式
    \begin{titlepage}                                       %
        \linespread{1.2} \sXiaosan \par                     % 1.2 倍行距
        \vspace{1\baselineskip}                             % 1 * 22pt * 1.2
        \begin{center}                                      %
            \fHei \sSanhao {学位论文评阅人和答辩委员会名单} \par
            #1\relax                                        %
        \end{center}                                        %
    \end{titlepage} \normalsize \newpage             %
    \thispagestyle{empty} \cleardoublepage}                 %
%%-----------------------------------------------------------------------------%
\cs_new_protected:Npn \reviewers #1 {                                 %
    \fSong \sDefault \vspace{\baselineskip}                 %
    \fSong \sSihao \vspace{0.3\baselineskip}                %
    \fHei \sSihao {学位论文评阅人名单} \par                 %
    \fSong \sSihao \vspace{0.3\baselineskip}                %
    \let\oldarraystretch=\arraystretch                      %
    \renewcommand{\arraystretch}{2.10}                      %
    \setlength{\tabcolsep}{2pt}                             %
    \begin{tabular}{O{3.71cm}O{2.83cm}O{8.73cm}}  %
        \sDefault \expert{\textbf{姓名}}{\textbf{职称}}{\textbf{工作单位}}
        #1\relax                                            %
    \end{tabular}                                          %
    \renewcommand{\arraystretch}{\oldarraystretch}}         %
%%-----------------------------------------------------------------------------%
\cs_new_protected:Npn \committee #1 #2 {                                 %
    \fSong \sDefault \vspace{\baselineskip}                 %
    \fSong \sSihao \vspace{0.3\baselineskip}                %
    \fHei \sSihao {答辩委员会名单} \par                     %
    \fSong \sSihao \vspace{-0.9\baselineskip}                %
    \let\oldarraystretch=\arraystretch                      %
    \renewcommand{\arraystretch}{2.10}                      %
    \setlength{\tabcolsep}{2pt}                             %
    \begin{tabular}{O{3.76cm}O{2.68cm}O{2.25cm}O{6.75cm}}
        \defenseDate{#1} \sDefault\textbf{答辩委员会} & %   %
        \expert{\textbf{姓名}}{\textbf{职称}}{\textbf{工作单位}}
        #2\relax                                            %
    \end{tabular}                                          %
    \renewcommand{\arraystretch}{\oldarraystretch}}         %
%%=============================================================================%

\ExplSyntaxOff
